# ==================================================
# VegSage — Environment Variables
# ==================================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
#
# Naming convention:
#   NEXT_PUBLIC_* → exposed to the browser (safe to be public)
#   Everything else → server-only (keep secret)
# ==================================================


# --------------------------------------------------
# App Configuration
# --------------------------------------------------

# Public base URL of the app (used for redirects, Paddle return URL, etc.)
# Dev: http://localhost:3000 | Prod: https://vegsage.com
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000


# --------------------------------------------------
# Contact & Legal
# --------------------------------------------------

# Support / legal contact address shown on legal pages and in emails
CONTACT_EMAIL=contact.vegsage@gmail.com

# Governing law jurisdiction shown in Terms of Service
# Default fallback: "Switzerland"
GOVERNING_LAW=Switzerland


# --------------------------------------------------
# Operator Legal Info  (required for legal pages before public launch)
# --------------------------------------------------

# Full legal name of the individual or company operating VegSage
OPERATOR_NAME=

# Street address of the operator (shown on /legal/contact)
OPERATOR_ADDRESS=

# Country of the operator (e.g. Switzerland, France, Germany)
OPERATOR_COUNTRY=


# --------------------------------------------------
# Supabase  (Auth + Database)
# --------------------------------------------------

# Project URL — found in Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=

# Anon / public key — safe to expose to the browser
# Found in Supabase Dashboard → Settings → API → Project API keys
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — bypasses Row Level Security, SERVER-ONLY
# Found in Supabase Dashboard → Settings → API → Project API keys
# Used by: /api/recalculate, /api/paddle/webhook, createAdminSupabaseClient()
SUPABASE_SERVICE_ROLE_KEY=


# --------------------------------------------------
# Database
# --------------------------------------------------

# Direct Postgres connection string (Supabase → Settings → Database → URI)
# Not used by the app directly (app connects via Supabase SDK above),
# but useful for local migrations, Prisma, or raw psql access.
DATABASE_URL=


# --------------------------------------------------
# Paddle Billing
# --------------------------------------------------

# Paddle environment — "sandbox" for testing, "production" for live
PADDLE_ENV=production
NEXT_PUBLIC_PADDLE_ENV=production

# Non-secret product and price IDs (can be committed if desired)
# Verify these match your Paddle dashboard before going live.
PADDLE_PRODUCT_ID=
PADDLE_PRICE_MONTHLY=pri_01kmhxc04ak23m0fpqdaq9rqs4r
PADDLE_PRICE_YEARLY=pri_01kmhxftr4a35v72bjvdvtec5r
NEXT_PUBLIC_PADDLE_PRICE_MONTHLY=pri_01kmhxc04ak23m0fpqdaq9rqs4r
NEXT_PUBLIC_PADDLE_PRICE_YEARLY=pri_01kmhxftr4a35v72bjvdvtec5r

# Paddle client-side token — safe for browser (NEXT_PUBLIC_*)
# Sandbox: token commençant par test_ | Live: token commençant par live_
# Found in Paddle Dashboard → Developer Tools → Authentication
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=

# Paddle API key — SERVER-ONLY, used to create checkout sessions
# Found in Paddle Dashboard → Developer Tools → Authentication
PADDLE_API_KEY=

# Paddle webhook signing secret — SERVER-ONLY
# Used to verify that webhook requests are genuinely from Paddle (HMAC-SHA256)
# Found in Paddle Dashboard → Developer Tools → Notifications → your webhook endpoint
PADDLE_WEBHOOK_SECRET=


# --------------------------------------------------
# USDA FoodData Central (primary food data source)
# --------------------------------------------------

# API key for USDA FDC — free at https://fdc.nal.usda.gov/api-guide.html
# Falls back to "DEMO_KEY" (rate-limited) if left empty.
# Get your free key at: https://api.data.gov/signup/
USDA_FDC_API_KEY=
